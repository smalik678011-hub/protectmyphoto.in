rules_version = '2';

service cloud.firestore {
  match /databases/{database}/documents {
    function isValidReview() {
      return request.resource.data.keys().hasOnly([
          'name',
          'rating',
          'reviewText',
          'timestamp',
          'userId',
          'clientId',
          'dayKey',
          'status'
        ])
        && request.resource.data.name is string
        && request.resource.data.name.size() >= 1
        && request.resource.data.name.size() <= 60
        && request.resource.data.rating is int
        && request.resource.data.rating >= 1
        && request.resource.data.rating <= 5
        && request.resource.data.reviewText is string
        && request.resource.data.reviewText.size() >= 12
        && request.resource.data.reviewText.size() <= 500
        && request.resource.data.timestamp == request.time
        && request.resource.data.clientId is string
        && request.resource.data.clientId.size() >= 8
        && request.resource.data.clientId.size() <= 80
        && request.resource.data.dayKey is string
        && request.resource.data.dayKey.matches('^\\d{4}-\\d{2}-\\d{2}$')
        && request.resource.data.status == 'approved';
    }

    match /reviews/{reviewId} {
      allow read: if true;
      allow create: if isValidReview()
        && (
          (request.auth != null && request.resource.data.userId == request.auth.uid)
          || (request.auth == null && request.resource.data.userId == null)
        );
      allow update, delete: if false;
    }
  }
}
